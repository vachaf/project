[31m-## 14. 발표용 한 줄 정리[m
[31m-[m
[31m-E세트는 OpenCart/PHP 환경에서 route parameter, PHP wrapper, config/admin path probing, SQLi/XSS query, POST body visibility를 검증하는 실험이다. 핵심은 PHP/OpenCart 특성을 활용하되, 실제 파일 노출·로그인 성공·SQLi 성공·XSS 실행은 Apache 로그만으로 단정하지 않는 것이다.[m
[32m+[m[41m[m
[32m+[m[32m---[m[41m[m
[32m+[m[41m[m
[32m+[m[32m## 5. Round 3 — OpenCart SQLi / XSS query 재검증[m[41m[m
[32m+[m[41m[m
[32m+[m[32mRound 3은 B/C세트 탐지 로직이 OpenCart URL 구조에도 일반화되는지 확인한다.[m[41m[m
[32m+[m[41m[m
[32m+[m[32m### E-21 Product Search SQLi[m[41m[m
[32m+[m[41m[m
[32m+[m[32m목적:[m[41m[m
[32m+[m[41m[m
[32m+[m[32m- OpenCart product/search 계열 query에서 SQLi payload가 query_string에 남을 때 탐지되는지 확인한다.[m[41m[m
[32m+[m[41m[m
[32m+[m[32m```bash[m[41m[m
[32m+[m[32mcurl -i -G \[m[41m[m
[32m+[m[32m  -A "${UA_PREFIX}-search-sqli-1" \[m[41m[m
[32m+[m[32m  --data-urlencode "route=product/search" \[m[41m[m
[32m+[m[32m  --data-urlencode "search=x')) OR 1=1 --" \[m[41m[m
[32m+[m[32m  "$OPENCART_URL/index.php"[m[41m[m
[32m+[m[32m```[m[41m[m
[32m+[m[41m[m
[32m+[m[32m기대 관찰:[m[41m[m
[32m+[m[41m[m
[32m+[m[32m- `route=product/search`, `search=` parameter 보존[m[41m[m
[32m+[m[32m- SQLi payload가 B세트와 유사하게 탐지되는지 확인[m[41m[m
[32m+[m[32m- response size anomaly가 있어도 실제 SQLi 성공 단정 금지[m[41m[m
[32m+[m[41m[m
[32m+[m[32m### E-22 Product Search XSS[m[41m[m
[32m+[m[41m[m
[32m+[m[32m목적:[m[41m[m
[32m+[m[41m[m
[32m+[m[32m- OpenCart product/search 계열 query에서 XSS payload가 query_string에 남을 때 탐지되는지 확인한다.[m[41m[m
[32m+[m[41m[m
[32m+[m[32m```bash[m[41m[m
[32m+[m[32mcurl -i -G \[m[41m[m
[32m+[m[32m  -A "${UA_PREFIX}-search-xss-1" \[m[41m[m
[32m+[m[32m  --data-urlencode "route=product/search" \[m[41m[m
[32m+[m[32m  --data-urlencode "search=<script>alert(1)</script>" \[m[41m[m
[32m+[m[32m  "$OPENCART_URL/index.php"[m[41m[m
[32m+[m[32m```[m[41m[m
[32m+[m[41m[m
[32m+[m[32m기대 관찰:[m[41m[m
[32m+[m[41m[m
[32m+[m[32m- XSS payload 탐지[m[41m[m
[32m+[m[32m- 브라우저 실행 성공은 단정하지 않음[m[41m[m
[32m+[m[32m- response body 반영 여부는 Apache 로그만으로 확정하지 않음[m[41m[m
[32m+[m[41m[m
[32m+[m[32m### E-23 Encoded XSS / Entity XSS[m[41m[m
[32m+[m[41m[m
[32m+[m[32m목적:[m[41m[m
[32m+[m[41m[m
[32m+[m[32m- C세트의 URL/entity decode 개선이 OpenCart query에서도 유지되는지 확인한다.[m[41m[m
[32m+[m[41m[m
[32m+[m[32m```bash[m[41m[m
[32m+[m[32mcurl -i -G \[m[41m[m
[32m+[m[32m  -A "${UA_PREFIX}-search-xss-entity-1" \[m[41m[m
[32m+[m[32m  --data-urlencode "route=product/search" \[m[41m[m
[32m+[m[32m  --data-urlencode "search=&#x3C;script&#x3E;alert(1)&#x3C;/script&#x3E;" \[m[41m[m
[32m+[m[32m  "$OPENCART_URL/index.php"[m[41m[m
[32m+[m[32m```[m[41m[m
[32m+[m[41m[m
[32m+[m[32m기대 관찰:[m[41m[m
[32m+[m[41m[m
[32m+[m[32m- HTML entity payload 식별[m[41m[m
[32m+[m[32m- `xss:html_entity_decoded_script` 계열 hint 유지[m[41m[m
[32m+[m[32m- SQL comment `#` 오탐 재발 방지[m[41m[m
[32m+[m[41m[m
[32m+[m[32m---[m[41m[m
[32m+[m[41m[m
[32m+[m[32m## 6. Round 4 — POST body visibility 재확인[m[41m[m
[32m+[m[41m[m
[32m+[m[32mRound 4는 OpenCart login/admin form에서 POST body visibility 한계를 다시 확인한다.[m[41m[m
[32m+[m[41m[m
[32m+[m[32m### E-31 Admin Login POST Baseline[m[41m[m
[32m+[m[41m[m
[32m+[m[32m목적:[m[41m[m
[32m+[m[41m[m
[32m+[m[32m- POST 요청이 Apache 로그 표면에서 어떻게 보이는지 확인한다.[m[41m[m
[32m+[m[41m[m
[32m+[m[32m```bash[m[41m[m
[32m+[m[32mcurl -i \[m[41m[m
[32m+[m[32m  -A "${UA_PREFIX}-post-login-base-1" \[m[41m[m
[32m+[m[32m  -H "Content-Type: application/x-www-form-urlencoded" \[m[41m[m
[32m+[m[32m  --data "username=admin&password=test" \[m[41m[m
[32m+[m[32m  "$OPENCART_URL/admin/index.php"[m[41m[m
[32m+[m[32m```[m[41m[m
[32m+[m[41m[m
[32m+[m[32m기대 관찰:[m[41m[m
[32m+[m[41m[m
[32m+[m[32m- method=POST[m[41m[m
[32m+[m[32m- req_content_type / req_content_length 기록[m[41m[m
[32m+[m[32m- raw POST body 원문은 baseline에서 보이지 않음[m[41m[m
[32m+[m[32m- 로그인 성공/실패 또는 계정 존재 여부는 Apache 로그만으로 확정하지 않음[m[41m[m
[32m+[m[41m[m
[32m+[m[32m### E-32 Admin Login SQLi POST[m[41m[m
[32m+[m[41m[m
[32m+[m[32m목적:[m[41m[m
[32m+[m[41m[m
[32m+[m[32m- POST body SQLi payload가 현재 baseline에서 직접 보이지 않는다는 점을 확인한다.[m[41m[m
[32m+[m[41m[m
[32m+[m[32m```bash[m[41m[m
[32m+[m[32mcurl -i \[m[41m[m
[32m+[m[32m  -A "${UA_PREFIX}-post-login-sqli-1" \[m[41m[m
[32m+[m[32m  -H "Content-Type: application/x-www-form-urlencoded" \[m[41m[m
[32m+[m[32m  --data "username=admin' OR '1'='1&password=x" \[m[41m[m
[32m+[m[32m  "$OPENCART_URL/admin/index.php"[m[41m[m
[32m+[m[32m```[m[41m[m
[32m+[m[41m[m
[32m+[m[32m기대 관찰:[m[41m[m
[32m+[m[41m[m
[32m+[m[32m- Apache 로그에는 method, URI, content-type, content-length 중심으로 남음[m[41m[m
[32m+[m[32m- body 내부 SQLi payload는 직접 보이지 않음[m[41m[m
[32m+[m[32m- Stage2는 POST body visibility 한계를 명시해야 함[m[41m[m
[32m+[m[32m- SQLi 성공 단정 금지[m[41m[m
[32m+[m[41m[m
[32m+[m[32m---[m[41m[m
[32m+[m[41m[m
[32m+[m[32m## 7. Round 5 — Directory probing sequence 일반성 확인[m[41m[m
[32m+[m[41m[m
[32m+[m[32mRound 5는 D세트 R3에서 개선한 `probing_sequence_summaries`가 OpenCart/PHP 경로에서도 동작하는지 확인한다.[m[41m[m
[32m+[m[41m[m
[32m+[m[32m```bash[m[41m[m
[32m+[m[32mfor path in \[m[41m[m
[32m+[m[32m  "/admin/" \[m[41m[m
[32m+[m[32m  "/admin/index.php" \[m[41m[m
[32m+[m[32m  "/config.php" \[m[41m[m
[32m+[m[32m  "/admin/config.php" \[m[41m[m
[32m+[m[32m  "/backup.zip" \[m[41m[m
[32m+[m[32m  "/backup.sql" \[m[41m[m
[32m+[m[32m  "/phpmyadmin" \[m[41m[m
[32m+[m[32m  "/vendor/" \[m[41m[m
[32m+[m[32m  "/storage/"; do[m[41m[m
[32m+[m[32m  curl -i --path-as-is \[m[41m[m
[32m+[m[32m    -A "${UA_PREFIX}-probe-burst-1" \[m[41m[m
[32m+[m[32m    "$OPENCART_URL${path}"[m[41m[m
[32m+[m[32m  sleep 1[m[41m[m
[32m+[m[32mdone[m[41m[m
[32m+[m[32m```[m[41m[m
[32m+[m[41m[m
[32m+[m[32m기대 관찰:[m[41m[m
[32m+[m[41m[m
[32m+[m[32m- 개별 요청을 candidate로 과승격하지 않음[m[41m[m
[32m+[m[32m- 같은 src_ip/window 내 3개 이상 민감/관리/백업 경로 접근을 `probing_sequence_summaries`로 보존[m[41m[m
[32m+[m[32m- 200/403/404 status 분포와 content-type/response size 반복성을 context로 전달[m[41m[m
[32m+[m[32m- 실제 config/admin/backup 노출 성공은 단정하지 않음[m[41m[m
[32m+[m[41m[m
[32m+[m[32m---[m[41m[m
[32m+[m[41m[m
[32m+[m[32m## 8. 실행 순서 권장[m[41m[m
[32m+[m[41m[m
[32m+[m[32mOpenCart E세트는 처음부터 전부 실행하지 말고 round별로 분리한다.[m[41m[m
[32m+[m[41m[m
[32m+[m[32m권장 순서:[m[41m[m
[32m+[m[41m[m
[32m+[m[32m1. E Round 0: URL/vhost/log 확인[m[41m[m
[32m+[m[32m2. E Round 1: route/admin probing[m[41m[m
[32m+[m[32m3. export + prepare + Stage1/Stage2 + 비교 문서[m[41m[m
[32m+[m[32m4. E Round 2: PHP wrapper/config exposure intent[m[41m[m
[32m+[m[32m5. export + 분석[m[41m[m
[32m+[m[32m6. E Round 3: SQLi/XSS query 재검증[m[41m[m
[32m+[m[32m7. export + 분석[m[41m[m
[32m+[m[32m8. E Round 4: POST body visibility[m[41m[m
[32m+[m[32m9. export + 분석[m[41m[m
[32m+[m[32m10. E Round 5: directory probing sequence 일반성 확인[m[41m[m
[32m+[m[32m11. E세트 통합 비교 문서 작성[m[41m[m
[32m+[m[41m[m
[32m+[m[32m한 export window에 모든 round를 섞지 않는 것이 좋다. OpenCart는 route, PHP wrapper, probing, POST body visibility의 평가 축이 다르기 때문이다.[m[41m[m
[32m+[m[41m[m
[32m+[m[32m---[m[41m[m
[32m+[m[41m[m
[32m+[m[32m## 9. 평가 기준[m[41m[m
[32m+[m[41m[m
[32m+[m[32m| 평가 축 | 성공 기준 | 보수적 해석 |[m[41m[m
[32m+[m[32m|---|---|---|[m[41m[m
[32m+[m[32m| Route parameter visibility | `route=`가 query_string에 보존됨 | route 처리 성공은 단정하지 않음 |[m[41m[m
[32m+[m[32m| PHP wrapper intent | `php://filter` decoded view가 확인됨 | source disclosure 성공은 body 없이는 미확정 |[m[41m[m
[32m+[m[32m| Config exposure intent | `/config.php`, `/admin/config.php` 접근 확인 | 파일 내용 노출 단정 금지 |[m[41m[m
[32m+[m[32m| SQLi query | `search=` 등 query parameter에 SQLi payload 보존 | DB 결과 변경/유출 단정 금지 |[m[41m[m
[32m+[m[32m| XSS query | query parameter에 XSS payload 보존 | 브라우저 실행/DOM 반영 단정 금지 |[m[41m[m
[32m+[m[32m| POST body | content-type/length 확인 | body payload는 직접 보이지 않음 |[m[41m[m
[32m+[m[32m| Probing sequence | `probing_sequence_summaries` 생성 | context-only, incident 과승격 금지 |[m[41m[m
[32m+[m[41m[m
[32m+[m[32m---[m[41m[m
[32m+[m[41m[m
[32m+[m[32m## 10. Provider 비교 포인트[m[41m[m
[32m+[m[41m[m
[32m+[m[32m| 비교 항목 | 확인 내용 |[m[41m[m
[32m+[m[32m|---|---|[m[41m[m
[32m+[m[32m| OpenCart route 이해 | `route=product/search`, `route=product/category`를 일반 query parameter로만 볼지, route abuse로 볼지 |[m[41m[m
[32m+[m[32m| PHP wrapper 보수성 | `php://filter`를 file disclosure intent로 보되 성공 단정은 피하는지 |[m[41m[m
[32m+[m[32m| Config file intent | config.php 접근을 sensitive file probe로 설명하는지 |[m[41m[m
[32m+[m[32m| POST body 한계 | raw body가 없을 때 SQLi/login 성공을 단정하지 않는지 |[m[41m[m
[32m+[m[32m| probing sequence | D세트 R3 개선 구조를 활용해 burst를 context-only로 설명하는지 |[m[41m[m
[32m+[m[32m| known asset 고려 | 내부 테스트/실험 가능성을 병기하는지 |[m[41m[m
[32m+[m[41m[m
[32m+[m[32m---[m[41m[m
[32m+[m[41m[m
[32m+[m[32m## 11. 산출물 관리[m[41m[m
[32m+[m[41m[m
[32m+[m[32mpublic repo 공개 권장:[m[41m[m
[32m+[m[41m[m
[32m+[m[32m- E세트 비교 Markdown[m[41m[m
[32m+[m[32m- 최종 Stage2 Markdown[m[41m[m
[32m+[m[32m- 통합 요약 문서[m[41m[m
[32m+[m[41m[m
[32m+[m[32mpublic repo 공개 비권장:[m[41m[m
[32m+[m[41m[m
[32m+[m[32m- raw export[m[41m[m
[32m+[m[32m- LLM input JSON[m[41m[m
[32m+[m[32m- Stage2 report input JSON[m[41m[m
[32m+[m[32m- analysis_candidates JSON[m[41m[m
[32m+[m[32m- noise_summary JSON[m[41m[m
[32m+[m[32m- stage1_errors JSON[m[41m[m
[32m+[m[41m[m
[32m+[m[32mOpenCart에서는 admin path, config path, route query, host/vhost 정보가 포함될 수 있으므로 raw/LLM input 공개에 더 주의한다.[m[41m[m
[32m+[m[41m[m
[32m+[m[32m---[m[41m[m
[32m+[m[41m[m
[32m+[m[32m## 12. 후속 코드 개선 후보[m[41m[m
[32m+[m[41m[m
[32m+[m[32mE세트 결과에 따라 다음을 검토한다.[m[41m[m
[32m+[m[41m[m
[32m+[m[32m1. PHP wrapper hint 세분화[m[41m[m
[32m+[m[32m   - `file_disclosure:php_filter_wrapper`[m[41m[m
[32m+[m[32m   - `file_disclosure:base64_source_intent`[m[41m[m
[32m+[m[41m[m
[32m+[m[32m2. OpenCart route parameter context[m[41m[m
[32m+[m[32m   - `opencart:route_parameter`[m[41m[m
[32m+[m[32m   - 단, OpenCart 전용 조건을 일반 탐지 score에 과하게 넣지 않음[m[41m[m
[32m+[m[41m[m
[32m+[m[32m3. config file probing hint[m[41m[m
[32m+[m[32m   - `file_probe:config_php`[m[41m[m
[32m+[m[32m   - `file_probe:admin_config_php`[m[41m[m
[32m+[m[41m[m
[32m+[m[32m4. POST body visibility 정책 유지/확장[m[41m[m
[32m+[m[32m   - raw POST body를 넣지 않는 현재 정책 유지가 기본[m[41m[m
[32m+[m[32m   - 실험 전용 body capture는 별도 보안 정책 필요[m[41m[m
[32m+[m[41m[m
[32m+[m[32m5. probing sequence generality[m[41m[m
[32m+[m[32m   - D세트 R3 개선 로직이 OpenCart에서도 불필요하게 과탐하지 않는지 확인[m[41m[m
[32m+[m[41m[m
[32m+[m[32m---[m[41m[m
[32m+[m[41m[m
[32m+[m[32m## 13. 최종 주의[m[41m[m
[32m+[m[41m[m
[32m+[m[32mE세트는 OpenCart/PHP라는 특정 앱을 대상으로 하지만, 코드 개선은 실험환경 특화가 되면 안 된다.[m[41m[m
[32m+[m[41m[m
